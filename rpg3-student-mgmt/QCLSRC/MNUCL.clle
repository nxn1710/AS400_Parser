/*================================================================*/
/* プログラム名: MNUCL                                             */
/* 説明        : 学生管理システム メニュー呼出CLプログラム          */
/* 作成日      : 2026/03/14                                        */
/* 作成者      : システム開発部                                    */
/*                                                                  */
/* 機能概要:                                                        */
/*   データベースファイルのオーバーライドを設定し、                  */
/*   メインメニュープログラム（MNUPRG）を呼び出す                  */
/*   エラー発生時はメッセージを送信して終了する                    */
/*                                                                  */
/* 使用ライブラリ:                                                  */
/*   STULIB - 学生管理システムライブラリ                            */
/*================================================================*/
             PGM

/*--------------------------------------------------------------*/
/* エラー監視: CPF0000系エラーを捕捉                              */
/*--------------------------------------------------------------*/
             MONMSG     MSGID(CPF0000) EXEC(GOTO CMDLBL(ERROR))

/*--------------------------------------------------------------*/
/* ライブラリリスト設定                                          */
/*--------------------------------------------------------------*/
             ADDLIBLE   LIB(STULIB)
             MONMSG     MSGID(CPF2103)

/*--------------------------------------------------------------*/
/* データベースファイル オーバーライド設定                        */
/* 物理ファイルと論理ファイルを明示的に指定する                  */
/*--------------------------------------------------------------*/
             OVRDBF     FILE(STUDNTPF) TOFILE(STULIB/STUDNTPF)
             OVRDBF     FILE(STUDNTL1) TOFILE(STULIB/STUDNTL1)
             OVRDBF     FILE(STUDNTL2) TOFILE(STULIB/STUDNTL2)
             OVRDBF     FILE(SCHOOLPF)  TOFILE(STULIB/SCHOOLPF)
             OVRDBF     FILE(CLASSPF)   TOFILE(STULIB/CLASSPF)

/*--------------------------------------------------------------*/
/* 表示ファイル オーバーライド設定                                */
/*--------------------------------------------------------------*/
             OVRDBF     FILE(MNUDSPF)   TOFILE(STULIB/MNUDSPF)
             OVRDBF     FILE(STUDSPF)   TOFILE(STULIB/STUDSPF)
             OVRDBF     FILE(STULSTD)   TOFILE(STULIB/STULSTD)

/*--------------------------------------------------------------*/
/* 印刷ファイル オーバーライド設定                                */
/*--------------------------------------------------------------*/
             OVRDBF     FILE(STURPTPF)  TOFILE(STULIB/STURPTPF)

/*--------------------------------------------------------------*/
/* メインメニュープログラム呼出                                  */
/*--------------------------------------------------------------*/
             CALL       PGM(STULIB/MNUPRG)
             MONMSG     MSGID(CPF0000)

/*--------------------------------------------------------------*/
/* オーバーライド削除                                            */
/*--------------------------------------------------------------*/
             DLTOVR     FILE(*ALL)

/*--------------------------------------------------------------*/
/* ライブラリリストから削除                                      */
/*--------------------------------------------------------------*/
             RMVLIBLE   LIB(STULIB)
             MONMSG     MSGID(CPF2104)

             GOTO       CMDLBL(ENDPGM)

/*--------------------------------------------------------------*/
/* エラー処理                                                    */
/*--------------------------------------------------------------*/
 ERROR:
             SNDPGMMSG  MSGID(CPF9898) MSGF(QCPFMSG) +
                          MSGDTA('学生管理システムでエラーが +
                          発生しました') MSGTYPE(*ESCAPE)

/*--------------------------------------------------------------*/
/* プログラム終了                                                */
/*--------------------------------------------------------------*/
 ENDPGM:
             ENDPGM
